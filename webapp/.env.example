# Zotero Web API — find your user ID and create a key at
# https://www.zotero.org/settings/keys (key needs library read access)
ZOTERO_USER_ID=
ZOTERO_API_KEY=

# Chat model provider: openai | anthropic | ollama
LLM_PROVIDER=openai
# Embedding provider: openai | ollama
EMBEDDING_PROVIDER=openai

# Required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Ollama (only used when a provider is set to ollama). No API key needed.
# Local run: default below works. Docker run: use host.docker.internal so the
# container can reach Ollama running on your machine.
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional overrides (defaults shown)
#LLM_MODEL=gpt-4o-mini          # anthropic default: claude-opus-4-8; ollama default: llama3.1
#EMBEDDING_MODEL=text-embedding-3-small   # ollama default: nomic-embed-text
#CHUNK_SIZE=1000
#CHUNK_OVERLAP=200
#RETRIEVAL_K=8
